{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "0f8a45e5850b4e9bb84c1cc26d26e485",
    "m_Group": {
        "m_Id": "b778409a9ec34e568b9f18bfd65a67de"
    },
    "m_Name": "RotateAboutYAxis (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -550.3999633789063,
            "y": -488.7999267578125,
            "width": 257.59991455078127,
            "height": 117.60000610351563
        }
    },
    "m_Slots": [
        {
            "m_Id": "9f18ab620aef49f5ad33271ccfa5c269"
        },
        {
            "m_Id": "f3d90a29f23e4ebda794ecc9aa766bdf"
        },
        {
            "m_Id": "9861508380eb475896ecba6d267a1497"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 1,
    "m_FunctionName": "RotateAboutYAxis",
    "m_FunctionSource": "",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#ifndef SCENESELECTIONPASS\nfloat s, c;\r\nsincos(Rotation, s, c);\nfloat3 Axis = float3(0,1,0);\rOut = In * c + cross(Axis, In) * s + Axis * dot(Axis, In) * (1 - c);\n#else\nOut = In;\n#endif\n"
}

